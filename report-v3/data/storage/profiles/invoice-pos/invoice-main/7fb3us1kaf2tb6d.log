{"type":"error","timestamp":1775920108979,"entity":{"shortid":"NnmocZQpoR","name":"invoice-main","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        @font-face {\n            font-family: 'Khmer OS Siemreap Regular';\n            src: url({{asset \"/invoice-pos/assets/Khmer OS Siemreap Regular.ttf\" \"dataURI\"}});\n            format('ttf');\n        }\n        {{asset \"/invoice-pos/assets/invoice-style.css\"}}\n    </style>\n</head>\n<body>\n    <div class=\"invoice\">\n        <div class=\"invoice-card\">\n            <header class=\"invoice-header\">\n                <img class=\"invoice-logo\" src=\"{{asset \\\"/invoice-pos/assets/pos-logo.png\\\" \\\"dataURI\\\"}}\" alt=\"POS logo\" />\n                <div class=\"invoice-service-title\">{{title_of_service}}</div>\n                <div class=\"invoice-address\">\n                    {{!-- Matches the target style shown by the user --}}\n                    Street 59B (H.E. Chea Sophara Street Phnom Penh, Sangkat Chrang Chamhres 2,<br>\n                    Khan Russey Keo, 12000), Cambodia\n                </div>\n                <div class=\"rule\"></div>\n                <div class=\"invoice-title\">Invoice</div>\n                <div class=\"invoice-title-rule\"></div>\n            </header>\n\n            <section class=\"invoice-meta\">\n                <div class=\"meta-labels\">\n                    <div>Invoice No :</div>\n                    <div>Cashier :</div>\n                    <div>Sale Date :</div>\n                </div>\n                <div class=\"meta-values\">\n                    <div>#{{receipt_number}}</div>\n                    <div>{{cashier.name}}</div>\n                    <div>{{formatDate ordered_at}}</div>\n                </div>\n            </section>\n\n            <main class=\"invoice-body\">\n                <table class=\"invoice-table\">\n                    <thead>\n                        <tr>\n                            <th>ល.រ</th>\n                            <th>ផលិតផល</th>\n                            <th>តម្លៃ(រៀល)</th>\n                            <th>ចំនួន</th>\n                            <th>សរុប</th>\n                        </tr>\n                    </thead>\n                    <tbody>\n                        {{#each details}}\n                        <tr>\n                            <td>{{increment}}</td>\n                            <td>{{product.name}}</td>\n                            <td>{{riel unit_price}}</td>\n                            <td>x {{qty}}</td>\n                            <td>{{subtotal unit_price qty}}</td>\n                        </tr>\n                        {{/each}}\n                    </tbody>\n                </table>\n            </main>\n\n            <footer class=\"invoice-footer\">\n                <div class=\"totals\">\n                    <div class=\"totals-row\">\n                        <span>តម្លៃសរុប :</span>\n                        <strong>{{riel total_price}}</strong>\n                    </div>\n                    <div class=\"totals-row\">\n                        <span>បញ្ចុះតម្លៃ :</span>\n                        <strong>0៛</strong>\n                    </div>\n                </div>\n                <div class=\"rule footer-rule\"></div>\n                <div class=\"thank-you\">Thank you for coming. See you again!</div>\n            </footer>\n        </div>\n    </div>\n</body>\n</html>\n"},"lineNumber":20,"property":"content","statusCode":400,"weak":true,"logged":true,"previousOperationId":"7k1k7ujysuvlibq","id":"tto7kcam54dumm2","stack":"Error: Parse error on line 20:\n...-logo\" src=\"{{asset \\\"/invoice-pos/asset\n-----------------------^\nExpecting 'CLOSE_RAW_BLOCK', 'CLOSE', 'CLOSE_UNESCAPED', 'OPEN_SEXPR', 'CLOSE_SEXPR', 'ID', 'OPEN_BLOCK_PARAMS', 'STRING'